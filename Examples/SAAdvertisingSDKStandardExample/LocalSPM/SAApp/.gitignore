# Created by https://gitignore.org
# Swift.gitignore

# User settings
xcuserdata/

# Obj-C/Swift specific
*.hmap

# App packaging
*.ipa
*.dSYM.zip
*.dSYM

# Playgrounds
timeline.xctimeline
playground.xcworkspace

# Swift Package Manager

# Packages/ - Swift Package Manager dependencies directory
#   - Contains resolved package sources downloaded locally.
#   - Should NOT be committed because:
#     - It's regenerated from Package.resolved when running swift package update or building.
#     - Keeping it saves build time during development but bloats the repo.
#     - Different team members might have different local package versions
Packages/

# Package.pins – Deprecated SPM lock format (SPM < Swift 5.1)
#   - Obsolete, but included for backwards compatibility with older projects.
#   - Modern projects use Package.resolved instead.
Package.pins

# Xcode automatically generates this directory with a .xcworkspacedata file and xcuserdata
# hence it is not needed unless you have added a package configuration file to your project
.swiftpm
.build/
DerivedData/
# Не игнорируем mirrors.json, так как он используется для работы с зависимостями
!.swiftpm/configuration/mirrors.json

# Tools
coverage.json
Package.env
*.xcresult
report.*
coverage
test-reports